---
const { src, size = 20, alt = "avatar" } = Astro.props;
---

<div
  style={`
    width: ${size}px;
    height: ${size}px;
    border-radius: 50%;
    overflow: hidden;
    display: inline-block;
  `}
>
  <img
    src={src}
    alt={alt}
    style={`
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    `}
  />
</div>
---

const base = import.meta.env.BASE_URL;

const sponsors = [
  { name: "Sociedade Brasileira de Física", type: "Apoio", color: "bg-blue-400",link: `${base}/Logo-SBF60-small_1.png` },
  { name: "IFES", type: "Instituição Organizadora", color: "bg-blue-600", link: `${base}/serra-vertical-cor.png`},
  { name: "UFES", type: "Parceiro Institucional", color: "bg-blue-500", link: `${base}/Logo_Ufes.png`},
  { name: "Governo do ES", type: "Apoio", color: "bg-slate-600", link: `${base}/Brasao_Governo.png`},
];
---

<section class="py-20 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-12">
      <h2 class="text-slate-900 text-3xl font-bold mb-2">
        Parceiros e Apoiadores
      </h2>
      <p class="text-slate-600">
        Organizações que tornam este evento possível
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-8">
      {sponsors.map((sponsor) => (
        <div class="flex flex-col items-center gap-3 p-6">
          <img src={sponsor.link} alt="">
        </div>
      ))}
    </div>

  </div>
</section>

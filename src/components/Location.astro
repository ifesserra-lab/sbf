<section id="local" class="py-20 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-12">
      <h2 class="text-slate-900 text-3xl sm:text-4xl font-bold mb-3">Local do Evento</h2>
      <p class="text-slate-500 text-sm">Instituto Federal do Espírito Santo</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-start">
      <div class="space-y-6">
        <div class="bg-slate-50 border border-slate-200 rounded-lg p-6">
          <div class="flex items-start gap-4 mb-4">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <div>
              <h3 class="text-slate-900 font-semibold mb-1">Endereço</h3>
              <p class="text-slate-600 text-sm leading-relaxed">
                Av. dos Sabiás, 330<br />
                Morada de Laranjeiras, Serra – ES<br />
                CEP: 29166-630
              </p>
            </div>
          </div>
          <a
            href="https://www.google.com/maps/place/IFES+-+Campus+Serra/@-20.1976491,-40.2202422,17z/data=!3m1!4b1!4m6!3m5!1s0xb81de52407d8d7:0x289693da8d05dd09!8m2!3d-20.1976491!4d-40.2176673!16s%2Fg%2F11gyc3xq80?entry=ttu&g_ep=EgoyMDI2MDQyNi4wIKXMDSoASAFQAw%3D%3D"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition-colors text-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-navigation w-4 h-4" data-fg-ywq23="7.17:7.3481:/src/app/components/Location.tsx:41:17:1940:34:e:Navigation::::::too" data-fgid-ywq23=":r3v:"><polygon points="3 11 22 2 13 21 11 13 3 11"></polygon></svg>Abrir no Google Maps
          </a>
        </div>

        <div class="bg-white border border-slate-200 rounded-lg p-6">
          <div class="flex items-start gap-4">
            <div>
              <h4 class="text-slate-900 font-semibold text-sm mb-1">Como chegar</h4>
              <p class="text-slate-600 text-sm leading-relaxed">
              Está localizado na ES-010, Km 6,5, Bairro Manguinhos, Serra-ES, a aproximadamente 20 km do centro de Vitória, acessível pela Rodovia Norte-Sul.</p>
            </div>
          </div>
        </div>

        <div class="bg-white border border-slate-200 rounded-lg p-6">
          <div class="flex items-start gap-4">
            <div>
              <h4 class="text-slate-900 font-semibold text-sm mb-1">Estacionamento</h4>
              <p class="text-slate-600 text-sm leading-relaxed">
                O IFES Serra possui estacionamento gratuito para participantes do evento.
              </p>
            </div>
          </div>
        </div>

      </div>

      <div class="rounded-xl overflow-hidden border border-slate-200 shadow-lg h-[40vh] lg:h-full">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3744.4731804121393!2d-40.220242224765606!3d-20.19764908125174!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xb81de52407d8d7%3A0x289693da8d05dd09!2sIFES%20-%20Campus%20Serra!5e0!3m2!1spt-BR!2sbr!4v1777466893607!5m2!1spt-BR!2sbr"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Local do evento UFES"
        ></iframe>
      </div>
    </div>
  </div>
</section>

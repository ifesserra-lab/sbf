---
import { Heart } from "@lucide/astro";

const sponsors = [
  { name: "IFES", color: "bg-green-700"},
  { name: "UFES", color: "bg-yellow-600"},
  { name: "SBF", color: "bg-red-800"},
];
---

<div class="border-t bg-slate-100/50 border-slate-200 py-10 px-4">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col items-center justify-center">
      <div class="flex items-center justify-center gap-2 mb-6 text-slate-600">
        <svg class="w-4 h-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
          <Heart size={20}/>
        </svg>
        <span class="text-sm font-medium">Agradecemos nossos patrocinadores e apoiadores</span>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-3">
        {sponsors.map((sponsor) => (
          <div class="flex items-center gap-2 px-4 py-2 rounded-lg border bg-white border-slate-200 hover:shadow-md cursor-default transition-all">
            <div class={`${sponsor.color} w-3 h-3 rounded-full flex-shrink-0`}>
            </div>
            <span class="text-sm font-semibold text-slate-800">{sponsor.name}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
